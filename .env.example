# Copy this file to ".env" and fill it with real values.
# Do not commit real secrets. Keep this file aligned with "src/env.js" and README.md.

# Required to run
DATABASE_URL="file:./db.sqlite"
# Site URL: single public base for the app (Mercado Pago back_urls and links).
# This value is always read from .env (no automatic derivation from Vercel URL).
# Local dev: http://localhost:3000
# Local dev + tunnel (ngrok, etc.): set URL to the https://... tunnel origin so MP redirects and webhooks hit your machine.
# Deploys (Vercel or non-Vercel): set the production site origin here.
URL="http://localhost:3000"
MERCADOPAGO_TOKEN=""
# Optional webhook base URL. If empty, URL is used. Keep this only when webhooks must use a different public origin.
# The app appends /api/webhook?source_news=webhooks in code.
WEBHOOK_URL=""
CRON_SECRET=""

# Required in production
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Hash format: scrypt:<salt>:<derived-key-hex>
# Generate with: pnpm admin:hash -- "your-password"
ADMIN_PASSWORD_HASH=""

# Optional internal access
EMPLOYEE_PASSWORD_HASH=""

# Payments and webhooks
WEBHOOK_SECRET=""

# Public prices and behavior
NEXT_PUBLIC_MAX_INTENDED_DAYS="30"
NEXT_PUBLIC_VOUCHER_PRICE="50"
NEXT_PUBLIC_VOUCHER_POOL_PRICE="70"
NEXT_PUBLIC_POOL_VOUCHER_PRICE="70"
NEXT_PUBLIC_ALERT_MESSAGE=""
NEXT_PUBLIC_ENABLE_ANALYTICS="false"
# Set automatically by Vercel when exposed as NEXT_PUBLIC_*; optional locally.
NEXT_PUBLIC_VERCEL_URL=""
NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=""

# Public info topics
NEXT_PUBLIC_INFO_CACHOEIRA_TITLE="Cachoeira"
NEXT_PUBLIC_INFO_CACHOEIRA_DESCRIPTION="Aproveite o contato direto com a natureza em uma cachoeira privilegiada de Pirenopolis-GO."
NEXT_PUBLIC_INFO_CACHOEIRA_IMAGE="/images/principais/cachoeira-principal.png"
NEXT_PUBLIC_INFO_RESTAURANTE_BAR_PE_DE_SERRA_TITLE="Restaurante e bar Pe de Serra"
NEXT_PUBLIC_INFO_RESTAURANTE_BAR_PE_DE_SERRA_DESCRIPTION="Comida de qualidade, atendimento acolhedor e estrutura para completar o seu passeio."
NEXT_PUBLIC_INFO_RESTAURANTE_BAR_PE_DE_SERRA_IMAGE="/images/principais/quiosque.png"
NEXT_PUBLIC_INFO_PISCINA_TITLE="Piscina"
NEXT_PUBLIC_INFO_PISCINA_DESCRIPTION="Area de piscina para adultos e criancas curtirem o dia com conforto."
NEXT_PUBLIC_INFO_PISCINA_IMAGE="/images/principais/piscina-drone.png"
NEXT_PUBLIC_INFO_PRAIA_TITLE="Praia"
NEXT_PUBLIC_INFO_PRAIA_DESCRIPTION="Espaco de praia para descansar, tomar sol e aproveitar o visual natural."
NEXT_PUBLIC_INFO_PRAIA_IMAGE="/images/principais/praia.jpg"
NEXT_PUBLIC_INFO_BAR_PE_NA_AREIA_TITLE="Bar pe na areia"
NEXT_PUBLIC_INFO_BAR_PE_NA_AREIA_DESCRIPTION="Bebidas e petiscos perto da area de lazer para voce relaxar sem pressa."
NEXT_PUBLIC_INFO_BAR_PE_NA_AREIA_IMAGE="/images/principais/piscinas-naturais.png"
NEXT_PUBLIC_INFO_REDEIRO_TITLE="Redeiro"
NEXT_PUBLIC_INFO_REDEIRO_DESCRIPTION="Area com redes para descansar entre um mergulho e outro."
NEXT_PUBLIC_INFO_REDEIRO_IMAGE="/images/principais/redario.png"

# Optional marketing and notifications
FACEBOOK_PIXEL_ID=""
FACEBOOK_ACCESS_TOKEN=""
GOOGLE_ANALYTICS_MEASUREMENT_ID=""
GOOGLE_ANALYTICS_API_SECRET=""
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""

# Optional Sentry monitoring
# NEXT_PUBLIC_SENTRY_DSN is safe to expose and enables browser monitoring.
NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_DSN may be the same DSN; used by server/route handlers.
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="0.1"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.05"
# Required only when uploading sourcemaps with sentry-cli / @sentry/nextjs during CI builds.
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
